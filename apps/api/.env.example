NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000,http://localhost:3001

# Database setup can be local MySQL, Docker MySQL, or remote MySQL.
DB_MODE=local-mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=saven_infraops
DATABASE_URL=mysql://infraops:infraops123@localhost:3306/saven_infraops

JWT_SECRET=change-this-in-production-use-64-char-secret
JWT_EXPIRES_IN=8h
PASSWORD_SALT_ROUNDS=12

SEED_ADMIN_EMAIL=admin@saven.in
SEED_ADMIN_PASSWORD=Admin@12345

MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback
MICROSOFT_ALLOWED_DOMAINS=saven.in

AI_ACTIVE_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
PRIVATE_MODEL_BASE_URL=http://localhost:11434
PRIVATE_MODEL_API_KEY=
PRIVATE_MODEL_NAME=llama3.1

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Saven InfraOps <infraops@saven.in>"
TEAMS_WEBHOOK_URL=

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20
