# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=Saven InfraOps Command Center

# API
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000,http://localhost:3001
# Database mode is documentation for setup. API always uses DATABASE_URL at runtime.
# Options: docker-mysql, local-mysql, remote-mysql
DB_MODE=local-mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=saven_infraops
DATABASE_URL=mysql://infraops:infraops123@localhost:3306/saven_infraops
JWT_SECRET=change-this-in-production-use-64-char-secret
JWT_EXPIRES_IN=8h
PASSWORD_SALT_ROUNDS=12

# Custom login seed admin
SEED_ADMIN_EMAIL=admin@saven.in
SEED_ADMIN_PASSWORD=Admin@12345

# Microsoft login
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback
MICROSOFT_ALLOWED_DOMAINS=saven.in

# AI provider switch. mock, openai, claude, private
AI_ACTIVE_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
PRIVATE_MODEL_BASE_URL=http://localhost:11434
PRIVATE_MODEL_API_KEY=
PRIVATE_MODEL_NAME=llama3.1

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Saven InfraOps <infraops@saven.in>"

# Microsoft Teams incoming webhook
TEAMS_WEBHOOK_URL=

# File upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20
